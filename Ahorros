b(1).FaceColor = azul;
b(2).FaceColor = naranja;
b(3).FaceColor = rojo;
b(4).FaceColor = verde;
b(5).FaceColor = morado;

hold on
grid on
box on

set(gca, ...
    'XTickLabel',{'Verano','Invierno','Total'}, ...
    'FontName',fontName, ...
    'FontSize',fontSize, ...
    'FontWeight','bold', ...
    'LineWidth',axisLineWidth);

ylabel('Ahorro mensual [MXN]', ...
    'FontName',fontName, ...
    'FontSize',fontSize, ...
    'FontWeight','bold');

title('Desglose de ahorros mensuales por componente tarifario', ...
    'FontName',fontName, ...
    'FontSize',fontSize+1, ...
    'FontWeight','bold');

h0 = plot(xlim,[0 0],'k','LineWidth',1.1);
set(get(get(h0,'Annotation'),'LegendInformation'),'IconDisplayStyle','off');

legend(b, {'Energía','Capacidad','Distribución','Factor de potencia','Total'}, ...
    'Location','northoutside', ...
    'Orientation','horizontal', ...
    'FontName',fontName, ...
    'FontSize',11);

yMin = min([0; Y(:)]);
yMax = max([0; Y(:)]);
margen = 0.18*(yMax-yMin);
ylim([yMin-margen yMax+margen]);

[nGrupos,nBarras] = size(Y);
groupwidth = min(0.8, nBarras/(nBarras+1.5));
offset = 0.025*(yMax-yMin);

for i = 1:nGrupos
    for j = 1:nBarras
        x = i - groupwidth/2 + (2*j-1)*groupwidth/(2*nBarras);
        y = Y(i,j);

        if y >= 0
            ytxt = y + offset;
            va = 'bottom';
        else
            ytxt = y - offset;
            va = 'top';
        end

        text(x,ytxt,char(fmtMoney.format(y)), ...
            'HorizontalAlignment','center', ...
            'VerticalAlignment',va, ...
            'FontName',fontName, ...
            'FontSize',9, ...
            'FontWeight','bold');
    end
end

